{
  "name": "visual-markdown-editor",
  "displayName": "Visual Markdown Editor",
  "description": "A feature-rich WYSIWYG markdown editor for VS Code with image management, formatting, colors, and tables",
  "version": "0.1.8",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:visualMarkdownEditor.convertSvgToPng"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "visualMarkdownEditor.editor",
        "displayName": "Visual Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          },
          {
            "filenamePattern": "*.mdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "visualMarkdownEditor.openVisualEditor",
        "title": "Open with Visual Markdown Editor"
      },
      {
        "command": "visualMarkdownEditor.newDocument",
        "title": "Visual Markdown: New Document"
      },
      {
        "command": "visualMarkdownEditor.openLinkedTextEditor",
        "title": "Visual Markdown: Open Linked Text Editor (for Copilot)"
      },
      {
        "command": "visualMarkdownEditor.focusLinkedTextEditor",
        "title": "Visual Markdown: Focus Linked Text Editor (for Copilot)"
      },
      {
        "command": "visualMarkdownEditor.convertSvgToPng",
        "title": "Convert to PNG"
      },
      {
        "command": "visualMarkdownEditor.showPreview",
        "title": "Open Visual Markdown Preview",
        "icon": "$(markdown)"
      },
      {
        "command": "visualMarkdownEditor.showPreviewToSide",
        "title": "Open Visual Markdown Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "visualMarkdownEditor.openSource",
        "title": "Open Source",
        "icon": "$(go-to-file)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "visualMarkdownEditor.openVisualEditor",
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation"
        },
        {
          "command": "visualMarkdownEditor.convertSvgToPng",
          "when": "resourceExtname == .svg",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "visualMarkdownEditor.showPreviewToSide",
          "when": "editorLangId == markdown && activeCustomEditorId != 'visualMarkdownEditor.editor'",
          "group": "navigation"
        },
        {
          "command": "visualMarkdownEditor.showPreview",
          "when": "editorLangId == markdown && activeCustomEditorId != 'visualMarkdownEditor.editor'",
          "group": "navigation"
        },
        {
          "command": "visualMarkdownEditor.openSource",
          "when": "activeCustomEditorId == 'visualMarkdownEditor.editor'",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "visualMarkdownEditor.openVisualEditor",
          "when": "resourceExtname == .md || resourceExtname == .markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.4",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "an-array-of-english-words": "^2.0.0",
    "html-to-docx": "^1.8.0",
    "marked": "^12.0.0",
    "mermaid": "^11.15.0",
    "puppeteer-core": "^24.43.1",
    "turndown": "^7.1.3",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
